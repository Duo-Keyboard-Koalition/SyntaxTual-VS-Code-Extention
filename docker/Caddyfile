{
	admin off
	auto_https off
}

:8080 {
	# VS Code (code-server, browser-native) under /code/
	handle_path /code/* {
		reverse_proxy 127.0.0.1:8443
	}

	# Cursor desktop, streamed via noVNC, under /cursor/
	handle_path /cursor/* {
		reverse_proxy 127.0.0.1:6080
	}

	# Antigravity desktop, streamed via noVNC, under /antigravity/
	handle_path /antigravity/* {
		reverse_proxy 127.0.0.1:6081
	}

	# The chooser landing page
	handle {
		root * /opt/landing
		file_server
	}
}
